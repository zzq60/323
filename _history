=\"计算 %a - %b\"\n    //% blockId=delNumbers\n    //% group=\"45积木\"\n    export function del(a: number, b: number): number {\n        return a - b\n    }\n}","pxt.json":"{\n    \"name\": \"323\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"main.py\",\n        \"custom.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}}],"shares":[],"lastSaveTime":1774537430372}